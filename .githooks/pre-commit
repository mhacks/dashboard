#!/bin/sh

set -eu

if [ ! -x ./node_modules/.bin/prettier ]; then
  printf "Prettier is not installed. Run pnpm install before committing.\n" >&2
  exit 1
fi

staged_files="$(mktemp)"
eslint_files="$(mktemp)"

cleanup() {
  rm -f "$staged_files" "$eslint_files"
}

trap cleanup EXIT

git diff --cached --name-only --diff-filter=ACMR -z > "$staged_files"

if [ ! -s "$staged_files" ]; then
  exit 0
fi

printf "Running Prettier on staged files...\n"
xargs -0 ./node_modules/.bin/prettier --write --ignore-unknown < "$staged_files"

tr '\0' '\n' < "$staged_files" | while IFS= read -r file; do
  case "$file" in
    *.cjs|*.cts|*.js|*.jsx|*.mjs|*.mts|*.ts|*.tsx)
      printf '%s\0' "$file"
      ;;
  esac
done > "$eslint_files"

if [ -s "$eslint_files" ]; then
  if [ ! -x ./node_modules/.bin/eslint ]; then
    printf "ESLint is not installed. Run pnpm install before committing.\n" >&2
    exit 1
  fi

  printf "Running ESLint fixes on staged JS/TS files...\n"
  xargs -0 ./node_modules/.bin/eslint --fix < "$eslint_files"
fi

xargs -0 git add -- < "$staged_files"
