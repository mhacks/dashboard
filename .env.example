# --- Local development (default) ---
# Start the local DB with `pnpm db:local`, then iterate with `pnpm db:push`.
# This is the standard connection string printed by `supabase start`.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# --- Shared remote (production / staging) ---
# Never put this in a committed file. Set it on your hosting platform, or pass it inline to migrate:
#   DATABASE_URL="<remote>" pnpm db:migrate
# Get the "Transaction" pooler string from: Supabase Dashboard -> Connect -> ORMs
# (host ends in pooler.supabase.com, port 6543).
#   postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# --- Supabase Auth (client + SSR) ---
# Local values are printed by `pnpm supabase status`. For the remote project,
# copy these from Supabase Dashboard -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Auth redirect allow-list. Read by supabase/config.toml via env(). Pick ONE host
# and use it everywhere (browser + emails) — localhost and 127.0.0.1 are different
# cookie origins. For the remote project, set these to your real domain.
SUPABASE_AUTH_SITE_URL="http://localhost:3000"
SUPABASE_AUTH_ADDITIONAL_REDIRECT_URLS="http://localhost:3000"
