    "lenis": "^1.3.23",
    "lucide-react": "^0.577.0",
    "next": "16.2.7",
    "postgres": "^3.4.9",
    "radix-ui": "^1.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20.19.42",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.6",
    "prettier": "^3.8.3",
